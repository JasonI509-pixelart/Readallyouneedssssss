        // DETERMINISTIC BADGE ENGINE (1,000,000 unique layers)
        function generateBadge(userId, index) {
            let hash = 0;
            const seedString = `${userId}-badge-layer-${index}`;
            for (let i = 0; i < seedString.length; i++) {
                hash = (hash << 5) - hash + seedString.charCodeAt(i);
                hash |= 0;
            }
            const absoluteLayer = Math.abs(hash) % 1000000;

            const colors = [
                { border: 'border-tomeOrange-500/30', bg: 'bg-tomeOrange-500/10', text: 'text-tomeOrange-500', icon: 'sparkles' },
                { border: 'border-tomeGreen-500/30', bg: 'bg-tomeGreen-500/10', text: 'text-tomeGreen-500', icon: 'shield' },
                { border: 'border-tomeBlue-500/30', bg: 'bg-tomeBlue-500/10', text: 'text-tomeBlue-500', icon: 'award' }
            ];
            const theme = colors[absoluteLayer % colors.length];

            const titles = ["Tome Seeker", "Emerald Comic Critic", "Orange Spark", "Blue Horizon", "Prose Alchemist", "Spine Guardian"];
            const title = titles[absoluteLayer % titles.length];

            return {
                layer: absoluteLayer,
                title: `${title} Layer #${absoluteLayer}`,
                theme: theme
            };
        }

