        // CALCULATE PRICING WITH DATE & USER ISOLATION RULES
        function calculatePrice(book) {
            let base = book.price || 4.00;

            // Rule 1: Holiday 75% off overrides everything else
            const holiday = getDetectedHoliday();
            if (holiday) {
                return (base * (1 - holiday.discount)).toFixed(2);
            }

            // Rule 2: First-time user discount (50% off first purchase)
            if (currentUser) {
                const owned = purchasedBooks[currentUser.id] || [];
                if (owned.length === 0) {
                    return (base * 0.50).toFixed(2);
                }
            }

            return base.toFixed(2);
        }

