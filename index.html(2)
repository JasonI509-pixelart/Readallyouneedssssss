        // AUTOMATIC DATE-BASED HOLIDAY ENGINE
        function getDetectedHoliday() {
            const today = new Date();
            const month = today.getMonth() + 1; // 1-12
            const date = today.getDate();       // 1-31

            // Christmas: Dec 24 - Dec 26
            if (month === 12 && (date >= 24 && date <= 26)) {
                return { name: "Christmas", icon: "🎄", discount: 0.75 };
            }
            // Halloween: Oct 30 - Nov 1
            if ((month === 10 && date >= 30) || (month === 11 && date === 1)) {
                return { name: "Halloween", icon: "🎃", discount: 0.75 };
            }
            // Easter Spring Window: April 10 - April 18
            if (month === 4 && (date >= 10 && date <= 18)) {
                return { name: "Easter", icon: "🐰", discount: 0.75 };
            }
            // New Year: Dec 31 - Jan 2
            if ((month === 12 && date === 31) || (month === 1 && (date === 1 || date === 2))) {
                return { name: "New Year", icon: "🎆", discount: 0.75 };
            }
            // Valentine's Day: Feb 13 - Feb 15
            if (month === 2 && (date >= 13 && date <= 15)) {
                return { name: "Valentine's", icon: "💖", discount: 0.75 };
            }

            return null; // No major holiday active
        }

