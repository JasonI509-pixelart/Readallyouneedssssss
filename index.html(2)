        // LOYALTY PROGRAM CALCULATIONS
        function getLoyaltyStats() {
            if (!currentUser) return { purchasedCount: 0, earnedCredits: 0, redeemedCredits: 0, availableCredits: 0, tier: 'Bronze', progressPercent: 0 };

            const ownedIds = purchasedBooks[currentUser.id] || [];
            const purchasedCount = ownedIds.length;

            let earnedCredits = 0;
            let tier = 'Bronze';
            let progressPercent = 0;

            if (purchasedCount >= 22) {
                earnedCredits = 5;
                tier = 'Mythic Diamond';
                progressPercent = 100;
            } else if (purchasedCount >= 16) {
                earnedCredits = 3;
                tier = 'Platinum Spark';
                progressPercent = Math.round((purchasedCount / 22) * 100);
            } else if (purchasedCount >= 10) {
                earnedCredits = 2;
                tier = 'Gold Star';
                progressPercent = Math.round((purchasedCount / 22) * 100);
            } else if (purchasedCount >= 3) {
                earnedCredits = 1;
                tier = 'Silver Crest';
                progressPercent = Math.round((purchasedCount / 22) * 100);
            } else {
                progressPercent = Math.round((purchasedCount / 3) * 100 * 0.3);
            }

            const redeemedCredits = currentUser.redeemedCredits || 0;
            const availableCredits = Math.max(0, earnedCredits - redeemedCredits);

            return {
                purchasedCount,
                earnedCredits,
                redeemedCredits,
                availableCredits,
                tier,
                progressPercent
            };
        }

