            closeAuthModal();
            updateAuthUI();
            applyUserThemeStyles();
            renderCatalog();
            triggerOllieTour();
            navigate('home');
        }

        function logout() {
            playSound('click');
            currentUser = null;
            isMasterAdmin = false;
            localStorage.removeItem('book_tome_current_user');
            
            document.getElementById('nav-admin').classList.add('hidden');
            document.getElementById('admin-unlocked-toast').classList.add('hidden');

            updateAuthUI();
            applyUserThemeStyles();
            navigate('home');
            renderCatalog();
        }

        function updateAuthUI() {
            const authSec = document.getElementById('auth-section');
            const userSec = document.getElementById('user-section');
            const navLibrary = document.getElementById('nav-library');
            const navProfile = document.getElementById('nav-profile');

            if (currentUser) {
                authSec.classList.add('hidden');
                userSec.classList.remove('hidden');
                navLibrary.classList.remove('hidden');
                navProfile.classList.remove('hidden');
                document.getElementById('user-display-name').innerText = currentUser.username;
                document.getElementById('user-avatar').innerText = currentUser.username.charAt(0).toUpperCase();
                
                if (isMasterAdmin) {
                    document.getElementById('nav-admin').classList.remove('hidden');
                }
            } else {
                authSec.classList.remove('hidden');
                userSec.classList.add('hidden');
                navLibrary.classList.add('hidden');
                navProfile.classList.add('hidden');
            }
        }

        // CHECKOUT WALLS & PURCHASE FLOW
        let activeCheckoutBookId = null;

        function triggerCheckout(bookId) {
            playSound('click');
            const book = books.find(b => b.id === bookId);
            if (!book) return;

            activeCheckoutBookId = bookId;
            document.getElementById('checkout-modal').classList.remove('hidden');
            document.getElementById('checkout-book-cover').src = book.coverUrl;
            document.getElementById('checkout-book-title').innerText = book.title;
            document.getElementById('checkout-book-genre').innerText = book.genre;

            const price = calculatePrice(book);
            document.getElementById('checkout-book-price').innerText = `$${price}`;
            document.getElementById('breakdown-base-price').innerText = `$${book.price.toFixed(2)}`;

            const isFirst = currentUser && (purchasedBooks[currentUser.id] || []).length === 0;
            const holiday = getDetectedHoliday();

            if (holiday || isFirst) {
                document.getElementById('checkout-discount-row').classList.remove('hidden');
                const discountAmt = (book.price - parseFloat(price)).toFixed(2);
                document.getElementById('checkout-discount-val').innerText = `-$${discountAmt}`;
                document.getElementById('checkout-discount-label').innerText = holiday ? `${holiday.name} Dynamic Promo` : "First Order Discount";
            } else {
                document.getElementById('checkout-discount-row').classList.add('hidden');
            }

            document.getElementById('breakdown-total-price').innerText = `$${price}`;

            const loyaltyStats = getLoyaltyStats();
            const loyaltyRow = document.getElementById('checkout-loyalty-row');
            const creditsCount = document.getElementById('checkout-credits-count');

            if (currentUser && loyaltyStats.availableCredits > 0) {
                loyaltyRow.classList.remove('hidden');
                creditsCount.innerText = loyaltyStats.availableCredits;
            } else {
                loyaltyRow.classList.add('hidden');
            }

            const authWarning = document.getElementById('checkout-auth-warning');
            const authBtn = document.getElementById('checkout-auth-btn');
            const payBtn = document.getElementById('checkout-pay-btn');

            if (!currentUser) {
                authWarning.classList.remove('hidden');
                authBtn.classList.remove('hidden');
                payBtn.classList.add('hidden');
            } else {
                authWarning.classList.add('hidden');
                authBtn.classList.add('hidden');
                payBtn.classList.remove('hidden');
            }
        }

        function closeCheckoutModal() {
            document.getElementById('checkout-modal').classList.add('hidden');
        }

        function routeGuestToAuth() {
            closeCheckoutModal();
            openAuthModal('signup', "Please create an account to secure checkout options.");
        }

        function processPurchase() {
            if (!currentUser || !activeCheckoutBookId) return;

            playSound('success');
            
            if (!purchasedBooks[currentUser.id]) {
                purchasedBooks[currentUser.id] = [];
            }
            purchasedBooks[currentUser.id].push(activeCheckoutBookId);
            localStorage.setItem('book_tome_purchased', JSON.stringify(purchasedBooks));

            const book = books.find(b => b.id === activeCheckoutBookId);
            if (book) {
                book.buyers = (book.buyers || 0) + 1;
                localStorage.setItem('book_tome_books', JSON.stringify(books));
            }

            alert(`🎉 Success! "${book.title}" has been permanently added to your personal sanctuary.`);
            closeCheckoutModal();
            renderCatalog();
            renderOwnedLibrary();
            updateLoyaltyUI();
            navigate('library');
        }

        // TRADITIONAL DOUBLE PAGE READER INTERFACE
        function launchBookReaderById(id) {
            const book = books.find(b => b.id === id);
            if (book) launchBookReader(book);
        }

        function launchBookReader(book) {
            playSound('page-flip');
            activeBook = book;
            activeBookPageIdx = 0;

            document.getElementById('book-reader-modal').classList.remove('hidden');
            document.getElementById('reader-title').innerText = book.title;
            document.getElementById('reader-genre-badge').innerText = book.genre;

            isReadingAloud = false;
            updateReadAloudButtonUI();

            updateReaderPages();
        }

        function updateReaderPages() {
            if (!activeBook) return;

            const leftPageText = document.getElementById('left-page-content');
            const rightPageText = document.getElementById('right-page-content');
            const leftPageNum = document.getElementById('left-page-num');
            const rightPageNum = document.getElementById('right-page-num');

            if (activeBookPageIdx === 0) {
                leftPageText.innerHTML = `
                    <div class="h-full flex flex-col justify-between text-center py-6 px-4 border-2 border-amber-900/10 rounded-xl bg-gradient-to-b from-amber-100/50 to-amber-50 relative overflow-hidden">
                        <div class="absolute inset-0 bg-cover bg-center opacity-10 pointer-events-none" style="background-image: url('${activeBook.coverUrl}')"></div>
                        <div>
                            <span class="text-[9px] uppercase tracking-widest font-bold text-amber-800/80">Premium Edition</span>
                            <h1 class="font-cinzel text-xl sm:text-2xl font-black text-amber-950 mt-4 leading-tight">${activeBook.title}</h1>
                            <div class="w-12 h-0.5 bg-amber-800 mx-auto my-3"></div>
                            <p class="text-xs font-serif italic text-amber-900/70">${activeBook.genre}</p>
                        </div>
                        <div class="my-4">
                            <img src="${activeBook.coverUrl}" class="w-24 h-32 object-cover mx-auto rounded shadow-lg border border-amber-900/20" onerror="handleCoverError(this)">
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-amber-900/60 uppercase tracking-wider">Book Tomes Storyverse</p>
                            <p class="text-[9px] text-amber-800/40 mt-1">Age Zone ${activeBook.ageZone}</p>
                        </div>
                    </div>
                `;
                leftPageNum.innerText = "Cover Page";

                const rightData = activeBook.pages[0];
                if (rightData) {
                    rightPageText.innerHTML = `
                        ${rightData.imageUrl ? `
                        <div class="w-full mb-4 overflow-hidden rounded-xl shadow-md border border-amber-900/10 bg-slate-900">
                            <img src="${rightData.imageUrl}" class="w-full h-44 object-cover hover:scale-105 transition-all duration-300" alt="Page Image" onerror="handleCoverError(this)">
                        </div>` : ''}
                        <p class="text-slate-800 leading-relaxed font-serif text-sm sm:text-base story-dropcap">${rightData.text}</p>
                    `;
                    rightPageNum.innerText = "Page 1";
                } else {
                    rightPageText.innerHTML = `<p class="text-amber-800/20 italic text-center py-20">The End</p>`;
                    rightPageNum.innerText = "";
                }
            } else {
                const leftData = activeBook.pages[activeBookPageIdx - 1];
                if (leftData) {
                    leftPageText.innerHTML = `
                        ${leftData.imageUrl ? `
                        <div class="w-full mb-4 overflow-hidden rounded-xl shadow-md border border-amber-900/10 bg-slate-900">
                            <img src="${leftData.imageUrl}" class="w-full h-44 object-cover hover:scale-105 transition-all duration-300" alt="Page Image" onerror="handleCoverError(this)">
                        </div>` : ''}
                        <p class="text-slate-800 leading-relaxed font-serif text-sm sm:text-base">${leftData.text}</p>
                    `;
                    leftPageNum.innerText = `Page ${activeBookPageIdx}`;
                } else {
                    leftPageText.innerHTML = `<p class="text-amber-800/20 italic text-center py-20">The End</p>`;
                    leftPageNum.innerText = "";
                }

                const rightData = activeBook.pages[activeBookPageIdx];
                if (rightData) {
                    rightPageText.innerHTML = `
                        ${rightData.imageUrl ? `
                        <div class="w-full mb-4 overflow-hidden rounded-xl shadow-md border border-amber-900/10 bg-slate-900">
                            <img src="${rightData.imageUrl}" class="w-full h-44 object-cover hover:scale-105 transition-all duration-300" alt="Page Image" onerror="handleCoverError(this)">
                        </div>` : ''}
                        <p class="text-slate-800 leading-relaxed font-serif text-sm sm:text-base">${rightData.text}</p>
                    `;
                    rightPageNum.innerText = `Page ${activeBookPageIdx + 1}`;
                } else {
                    rightPageText.innerHTML = `<p class="text-amber-800/20 italic text-center py-20">The End</p>`;
                    rightPageNum.innerText = "";
                }
            }

            const totalPages = activeBook.pages.length + 1;
            const currentPosition = activeBookPageIdx === 0 ? 1 : activeBookPageIdx + 1;
            const progress = Math.min(100, Math.round((currentPosition / totalPages) * 100));
            document.getElementById('book-progress-indicator').innerText = `Reading Progress: ${progress}%`;

            if (isReadingAloud) {
                speakCurrentSpread();
            }
        }

        function prevBookPage() {
            if (activeBookPageIdx > 0) {
                playSound('page-flip');
                activeBookPageIdx = Math.max(0, activeBookPageIdx - 2);
                updateReaderPages();
            }
        }

        function nextBookPage() {
            if (activeBook) {
                const totalStoryPages = activeBook.pages.length;
                if (activeBookPageIdx + 2 <= totalStoryPages) {
                    playSound('page-flip');
                    activeBookPageIdx += 2;
                    updateReaderPages();
                } else {
                    playSound('success');
                    alert("🎉 You have reached the end of this beautiful tale!");
                }
            }
        }

        // READ ALOUD ON/OFF TOGGLE
        function toggleReadAloud() {
            if (!activeBook) return;

            isReadingAloud = !isReadingAloud;
            updateReadAloudButtonUI();

            if (isReadingAloud) {
                playSound('success');
                speakCurrentSpread();
            } else {
                playSound('click');
                if ('speechSynthesis' in window) {
                    window.speechSynthesis.cancel();
                }
            }
        }

        function updateReadAloudButtonUI() {
            const btn = document.getElementById('read-aloud-btn');
            if (isReadingAloud) {
                btn.className = "bg-gradient-to-r from-tomeGreen-500 to-tomeGreen-600 text-slate-950 font-bold px-4 py-2 rounded-lg text-xs transition flex items-center gap-1.5 shadow-md";
                btn.innerHTML = `<i data-lucide="volume-2" class="w-3.5 h-3.5"></i> Read Aloud: ON`;
            } else {
                btn.className = "bg-gradient-to-r from-red-500 to-red-600 text-white font-bold px-4 py-2 rounded-lg text-xs transition flex items-center gap-1.5 shadow-md";
                btn.innerHTML = `<i data-lucide="volume-x" class="w-3.5 h-3.5"></i> Read Aloud: OFF`;
            }
            lucide.createIcons();
        }

        function speakCurrentSpread() {
            if (!('speechSynthesis' in window)) {
                alert("⚠️ Web Speech API is not supported in this browser.");
                return;
            }

            window.speechSynthesis.cancel(); // Stop current speech

            const selectedVoiceName = document.getElementById('reader-voice-select').value;
            let textToRead = "";

            if (activeBookPageIdx === 0) {
                textToRead += `${activeBook.title}. A ${activeBook.genre} tale. `;
                const page1 = activeBook.pages[0];
                if (page1) textToRead += page1.text;
            } else {
                const leftPage = activeBook.pages[activeBookPageIdx - 1];
                const rightPage = activeBook.pages[activeBookPageIdx];
                if (leftPage) textToRead += leftPage.text + " ";
                if (rightPage) textToRead += rightPage.text;
            }

            if (textToRead.trim() === "") return;

            const utterance = new SpeechSynthesisUtterance(textToRead);
            const voices = window.speechSynthesis.getVoices();
            const isFemaleName = ["Aria", "Luna", "Nova", "Sage", "Celeste", "Ivy", "Ember", "Pearl", "Zara"].includes(selectedVoiceName);
            
            let voiceToUse = null;
            for (let v of voices) {
                const lName = v.name.toLowerCase();
                if (isFemaleName && (lName.includes('female') || lName.includes('zira') || lName.includes('samantha') || lName.includes('google us english') || lName.includes('hazel'))) {
                    voiceToUse = v;
                    break;
                } else if (!isFemaleName && (lName.includes('male') || lName.includes('david') || lName.includes('google uk english') || lName.includes('ravi'))) {
                    voiceToUse = v;
                    break;
                }
            }

            if (voiceToUse) utterance.voice = voiceToUse;
            utterance.rate = 0.95;
            utterance.pitch = isFemaleName ? 1.1 : 0.9;

            window.speechSynthesis.speak(utterance);
        }

        function closeBookReader() {
            if (window.speechSynthesis) {
                window.speechSynthesis.cancel();
            }
            document.getElementById('book-reader-modal').classList.add('hidden');
            activeBook = null;
            isReadingAloud = false;
        }

        // ONBOARDING OWL TOUR
        let currentTourStep = 0;
        const tourSteps = [
            { text: "Hoot! I'm Ollie, your magical library guide. Let me show you around Book Tomes!", target: null },
            { text: "Use our descriptive search bar to tell us exactly what kind of book you want to read. (Psst... admins can enter master passwords here!)", target: "main-search" },
            { text: "Browse the Grand Library catalog below. Click 'Browse 100 Genres' to see our newly expanded categorization!", target: "catalog-grid" },
            { text: "Click on any book card to open a traditional page-flip layout reader with a center spine and fixed navigation.", target: "catalog-grid" },
            { text: "Create an account to unlock your personal Sanctuary Library and track your progress.", target: "auth-section" },
            { text: "Every user gets stable deterministic badges (up to 1,000,000 possibilities!) generated from their unique ID.", target: "nav-profile" },
            { text: "Ready to explore? Standard base pricing is $4.00, but watch out for automatic holiday discounts of up to 75% off! Let's read!", target: null }
        ];

        function checkOllieTour() {
            const completed = localStorage.getItem('book_tome_tour_completed');
            if (!completed && currentUser) {
                triggerOllieTour();
            }
        }

        function triggerOllieTour() {
            currentTourStep = 0;
            document.getElementById('ollie-tour-container').classList.remove('hidden');
            showTourStep();
        }

        function showTourStep() {
            playSound('hoot');
            const step = tourSteps[currentTourStep];
            document.getElementById('tour-step-num').innerText = `${currentTourStep + 1}/${tourSteps.length}`;
            document.getElementById('tour-step-text').innerText = step.text;

            if (step.target) {
                const el = document.getElementById(step.target);
                if (el) {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    el.classList.add('ring-4', 'ring-tomeOrange-500', 'ring-offset-4', 'ring-offset-slate-950');
                    setTimeout(() => {
                        el.classList.remove('ring-4', 'ring-tomeOrange-500', 'ring-offset-4', 'ring-offset-slate-950');
                    }, 3000);
                }
            }
        }

        function nextTourStep() {
            currentTourStep++;
            if (currentTourStep < tourSteps.length) {
                showTourStep();
            } else {
                skipTour();
            }
        }

        function skipTour() {
            playSound('success');
            localStorage.setItem('book_tome_tour_completed', 'true');
            document.getElementById('ollie-tour-container').classList.add('hidden');
        }

        // MULTIMEDIA PAGE-BY-PAGE EDITOR
        function openMultimediaEditor(bookId) {
            playSound('click');
            const book = books.find(b => b.id === bookId);
            if (!book) return;

            selectedMediaBook = book;
            selectedMediaPageIdx = 0;

            document.getElementById('multimedia-editor-modal').classList.remove('hidden');
            renderMediaPagesList();
            loadSelectedMediaPage();
        }

        function renderMediaPagesList() {
            const container = document.getElementById('media-pages-list');
            container.innerHTML = '';

            selectedMediaBook.pages.forEach((page, idx) => {
                const btn = document.createElement('button');
                btn.className = `w-full text-left p-3 rounded-xl border text-xs flex items-center justify-between transition ${idx === selectedMediaPageIdx ? 'bg-tomeOrange-500/10 border-tomeOrange-500 text-tomeOrange-500 font-bold' : 'bg-slate-950 border-slate-800 text-slate-400 hover:text-white'}`;
                
                btn.onclick = () => {
                    playSound('click');
                    selectedMediaPageIdx = idx;
                    renderMediaPagesList();
                    loadSelectedMediaPage();
                };

                btn.innerHTML = `
                    <span>Page #${idx + 1}</span>
                    ${page.imageUrl ? `<span class="text-xs" title="Visual Fitted">🖼️</span>` : ''}
                `;
                container.appendChild(btn);
            });
        }

        function loadSelectedMediaPage() {
            const page = selectedMediaBook.pages[selectedMediaPageIdx];
            document.getElementById('editing-page-label').innerText = `Page #${selectedMediaPageIdx + 1}`;
            document.getElementById('editing-page-text').value = page.text;
            document.getElementById('editing-page-image-url').value = page.imageUrl || '';
        }

        function clearPageImage() {
            playSound('click');
            document.getElementById('editing-page-image-url').value = '';
        }

        function commitLayoutRedesign() {
            playSound('click');
            const text = document.getElementById('editing-page-text').value;
            const imageUrl = document.getElementById('editing-page-image-url').value;

            const progressContainer = document.getElementById('layout-progress-container');
            progressContainer.classList.remove('hidden');

            let progress = 0;
            const interval = setInterval(() => {
                progress += 20;
                document.getElementById('layout-progress-bar').style.width = `${progress}%`;
                document.getElementById('layout-progress-text').innerText = `${progress}%`;

                if (progress >= 100) {
                    clearInterval(interval);
                    
                    selectedMediaBook.pages[selectedMediaPageIdx].text = text;
                    selectedMediaBook.pages[selectedMediaPageIdx].imageUrl = imageUrl || null;

                    localStorage.setItem('book_tome_books', JSON.stringify(books));

                    progressContainer.classList.add('hidden');
                    document.getElementById('layout-progress-bar').style.width = '0%';

                    playSound('success');
                    alert("🎨 AI Layout Engine has finished redesigning the prose and wrapping visuals beautifully!");
                    renderMediaPagesList();
                    loadSelectedMediaPage();
                    renderAdminPage();
                    renderCatalog();
                }
            }, 300);
        }

        function closeMultimediaEditor() {
            document.getElementById('multimedia-editor-modal').classList.add('hidden');
            selectedMediaBook = null;
        }
    </script>
</body>
</html>
