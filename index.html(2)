    <meta name="robots" content="index, follow">
    <link class="seo-meta" rel="canonical" href="https://booktome-lsyxfp.composed.app">
    
    <!-- Google Verification Meta Tag -->
    <meta name="google-site-verification" content="bt_verification_wildcard_9928173" />
    
    <!-- Structured JSON-LD Data for Google Search Indexing -->
    <script type="application/ld+json" id="structured-data-json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Book Tomes",
      "url": "https://booktome-lsyxfp.composed.app",
      "description": "Discover deep, page-filling children epics on booktome-lsyxfp.composed.app. Experience funny stories like Captain Cardboard, Chronicles of a Clumsy Coder, and Inspector Paws.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://booktome-lsyxfp.composed.app/?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                        cinzel: ['Cinzel', 'serif'],
